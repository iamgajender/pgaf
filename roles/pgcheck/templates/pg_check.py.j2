#!/usr/bin/env python3

import json
import subprocess

from http.server import BaseHTTPRequestHandler
from http.server import HTTPServer

HOST = "0.0.0.0"
PORT = {{ pgcheck_port }}

MONITOR_PGDATA = "{{ monitor_pgdata }}"

LOCAL_HOST = "{{ inventory_hostname }}"


def run(cmd):

    result = subprocess.run(
        cmd,
        shell=True,
        capture_output=True,
        text=True
    )

    return result.returncode, result.stdout.strip(), result.stderr.strip()


##############################################################################
# Local PostgreSQL
##############################################################################

def local_is_primary():

    cmd = (
        "psql -Atqc "
        "\"SELECT NOT pg_is_in_recovery();\""
    )

    rc, out, err = run(cmd)

    if rc != 0:
        return False

    return out == "t"


##############################################################################
# Monitor State
##############################################################################

def monitor_primary():

    cmd = (
        "pg_autoctl show state "
        "--pgdata {} "
        "--json".format(MONITOR_PGDATA)
    )

    rc, out, err = run(cmd)

    if rc != 0:
        return None

    nodes = json.loads(out)

    for node in nodes:

        if node["current_group_state"] == "primary":
            return node["nodehost"]

    return None


##############################################################################
# HTTP
##############################################################################

class Handler(BaseHTTPRequestHandler):

    def do_GET(self):

        primary = monitor_primary()

        local_primary = local_is_primary()

        if primary == LOCAL_HOST and local_primary:

            self.send_response(200)

            self.end_headers()

            self.wfile.write(b"PRIMARY")

        else:

            self.send_response(503)

            self.end_headers()

            self.wfile.write(b"STANDBY")


##############################################################################

server = HTTPServer((HOST, PORT), Handler)

server.serve_forever()
